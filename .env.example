# ─── Email (SMTP) ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASSWORD=your_app_password        # Gmail → Settings → App Passwords
EMAIL_FROM_NAME=Tech Radar Agent

# ─── LLM (optional — needed only if llm.enabled=true in config.yaml) ─────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...                  # alternative provider

# ─── Reddit API ───────────────────────────────────────────────────────────────
# Create app at https://www.reddit.com/prefs/apps (script type)
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USER_AGENT=TechRadarBot/1.0 by YourUsername

# ─── GitHub ───────────────────────────────────────────────────────────────────
# Personal Access Token (read:public_repo scope is enough)
GITHUB_TOKEN=ghp_...

# ─── YouTube (optional) ───────────────────────────────────────────────────────
# Enable API at https://console.developers.google.com
YOUTUBE_API_KEY=AIza...
